@page "/tournament"
@rendermode InteractiveServer
@inject SimulationService Simulator
@inject OloraculoDbContext Db
@inject IOptions<OloraculoConfig> Options
@inject ISnackbar Snackbar

<PageTitle>Torneo</PageTitle>

<MudStack Spacing="3">
    <div class="page-head">
        <MudText Typo="Typo.h3">Torneo</MudText>
        <MudText Typo="Typo.body1" Color="Color.Secondary">Proyección Monte Carlo con la estructura oficial de grupos y eliminación directa de 2026.</MudText>
    </div>

    <MudPaper Class="surface-card" Elevation="0">
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="action-row">
            <BusyButton Text="Correr simulación" BusyText="Simulando torneo" IsBusy="_busy" Icon="@Icons.Material.Filled.PlayArrow" OnClick="Run" />
            <MudButton Href="tournament/snapshots" Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.History">Ver snapshots</MudButton>
            <MudSpacer />
            <MudText Typo="Typo.body2" Color="Color.Secondary">@Options.Value.SimulationCount.ToString("N0") simulaciones configuradas</MudText>
        </MudStack>
        @if (_busy)
        {
            <MudProgressLinear Class="inline-progress" Color="Color.Primary" Indeterminate="true" />
            <MudText Typo="Typo.caption" Color="Color.Secondary">Corriendo @Options.Value.SimulationCount.ToString("N0") simulaciones configuradas...</MudText>
        }
        @if (_projection is not null)
        {
            <MudText Typo="Typo.caption" Color="Color.Secondary">@_projection.Simulations.ToString("N0") simulaciones | @_projection.InputSummaryHash</MudText>
        }
    </MudPaper>

    @if (!string.IsNullOrWhiteSpace(_error))
    {
        <MudAlert Severity="Severity.Error" Variant="Variant.Outlined">@_error</MudAlert>
    }

    @if (_projection is not null)
    {
        <MudPaper Class="surface-card" Elevation="0">
            <MudText Typo="Typo.h6">Probabilidad de campeón</MudText>
            <MudTable Items="_projection.Teams.Take(32)" Dense="true" Hover="true" Elevation="0" Class="dense-table">
                <HeaderContent>
                    <MudTh>Equipo</MudTh>
                    <MudTh Class="num">Clasifica</MudTh>
                    <MudTh Class="num">16avos</MudTh>
                    <MudTh Class="num">4tos</MudTh>
                    <MudTh Class="num">Semis</MudTh>
                    <MudTh Class="num">Final</MudTh>
                    <MudTh Class="num">Campeón</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Equipo"><TeamLabel TeamId="@context.TeamId" Name="@Name(context.TeamId)" /></MudTd>
                    <MudTd DataLabel="Clasifica" Class="num">@context.Qualify.ToString("P0")</MudTd>
                    <MudTd DataLabel="16avos" Class="num">@context.ReachRoundOf16.ToString("P0")</MudTd>
                    <MudTd DataLabel="4tos" Class="num">@context.ReachQuarterFinal.ToString("P0")</MudTd>
                    <MudTd DataLabel="Semis" Class="num">@context.ReachSemiFinal.ToString("P0")</MudTd>
                    <MudTd DataLabel="Final" Class="num">@context.ReachFinal.ToString("P0")</MudTd>
                    <MudTd DataLabel="Campeón" Class="num"><strong>@context.WinTournament.ToString("P1")</strong></MudTd>
                </RowTemplate>
            </MudTable>
        </MudPaper>
    }
</MudStack>

@code {
    private bool _busy;
    private string _error = "";
    private TournamentProjection? _projection;
    private Dictionary<string, string> _names = [];

    protected override async Task OnInitializedAsync() =>
        _names = await Db.Teams.ToDictionaryAsync(t => t.Id, t => t.Name);

    private async Task Run()
    {
        _busy = true;
        _error = "";
        StateHasChanged();
        await Task.Yield();
        try
        {
            _projection = await Simulator.RunAsync(Options.Value.SimulationCount);
            Snackbar.Add("Simulación completa.", Severity.Success);
        }
        catch (Exception ex)
        {
            _error = ex.Message;
            Snackbar.Add("No se pudo correr la simulación.", Severity.Error);
        }
        finally
        {
            _busy = false;
        }
    }

    private string Name(string id) => _names.TryGetValue(id, out var name) ? name : id;
}
