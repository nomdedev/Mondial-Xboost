# Exclude heavy/non-essential dirs from Vercel build
models/
scripts/
tests/
docs/
backtest/
scrapers/
.git/
.venv/
venv/
__pycache__/
.ruff_cache/
*.parquet
Makefile
requirements-lock.txt
requirements-dev.txt
requirements_uvicorn.txt
.cursorrules
CLAUDE.md
AGENTS.md

# Keep only the canonical model artifacts required by predictors/api.py.
data/*/
!data/models/
data/models/*
!data/models/xgboost_football_outcome.pkl
!data/models/xgboost_football_home_goals.pkl
!data/models/xgboost_football_away_goals.pkl
!data/models/xgboost_football_meta.json
!data/models/model_manifest.json

# CSVs are excluded by default, but the canonical historical dataset is needed
# by the prediction endpoint.
*.csv
!MondialXboost.Web/Data/historical_results.csv
