root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.{cs,cshtml,razor}]
indent_size = 4
indent_style = space
max_line_length = 120

[*.{py,js,ts,json,yml,yaml}]
indent_size = 4
indent_style = space
max_line_length = 120

[*.md]
trim_trailing_whitespace = false
