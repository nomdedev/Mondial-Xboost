{
  "builds": [
    {
      "src": "predictors/api.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/static/(.*)",
      "dest": "/static/$1"
    },
    {
      "src": "/(.*)",
      "dest": "predictors/api.py"
    }
  ],
  "installCommand": "pip install -r requirements-vercel.txt"
}
