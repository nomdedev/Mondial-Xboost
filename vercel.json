{
  "framework": null,
  "installCommand": "pip install -r requirements-vercel.txt",
  "env": {
    "MODELS_DIR": "predictors/models"
  },
  "functions": {
    "api/*.py": {
      "includeFiles": "predictors/models/**,data/prepared/**,data/wc2026_fixtures.json,data/wc2026_predictions.json,data/wc2026_tournament.json",
      "memory": 2048,
      "maxDuration": 300
    }
  },
  "rewrites": [
    { "source": "/(.*)", "destination": "/api/index.py" }
  ]
}
