"""
Integration Tests — API-Football + News Scraper + ETL
======================================================
Tests all data pipeline components.

Run:
    pytest tests/test_integration.py -v
"""
import os
import sys
import pytest
import pandas as pd
from pathlib import Path

# Add project root to path
sys.path.insert(0, str(Path(__file__).parent.parent))

from scrapers.player_stats_service import PlayerStatsService
from scrapers.news_scraper_service import NewsScraperService
from predictors.etl import ETLPipeline
from predictors.feature_engineering import FeatureEngineer


class TestPlayerStatsService:
    """Test API-Football connector."""
    
    @pytest.fixture
    def api_key(self):
        key = os.getenv("API_FOOTBALL_KEY", "")
        if not key:
            pytest.skip("API_FOOTBALL_KEY not set")
        return key
    
    @pytest.fixture
    def service(self, api_key):
        return PlayerStatsService(api_key=api_key, season=2026)
    
    def test_get_leagues(self, service):
        """Test fetching leagues."""
        leagues = service.get_leagues(season=2026)
        assert isinstance(leagues, list)
        print(f"Found {len(leagues)} leagues")
    
    def test_get_team_squad(self, service):
        """Test fetching team squad."""
        # Argentina = team_id 26
        squad = service.get_team_squad(team_id=26)
        assert isinstance(squad, list)
        assert len(squad) > 0
        print(f"Argentina squad: {len(squad)} players")
    
    def test_get_team_stats(self, service):
        """Test fetching team statistics."""
        # World Cup league_id varies, test with a known league
        stats = service.get_team_stats(team_id=26, league_id=1, season=2022)
        assert isinstance(stats, dict)
        print(f"Team stats keys: {list(stats.keys())[:5]}")
    
    def test_cache_works(self, service):
        """Test that caching works."""
        # First call
        squad1 = service.get_team_squad(team_id=26)
        # Second call should be cached
        squad2 = service.get_team_squad(team_id=26)
        assert len(squad1) == len(squad2)


class TestNewsScraperService:
    """Test news scraper."""
    
    @pytest.fixture
    def scraper(self):
        return NewsScraperService(headless=True)
    
    def test_scrape_espn(self, scraper):
        """Test scraping ESPN injury tracker."""
        articles = scraper.scrape_source("espn_injuries")
        assert isinstance(articles, list)
        print(f"ESPN articles: {len(articles)}")
        
        if articles:
            article = articles[0]
            assert article.title
            assert article.content
            print(f"First article: {article.title[:100]}")
    
    def test_scrape_talksport(self, scraper):
        """Test scraping TalkSport."""
        articles = scraper.scrape_source("talksport_injuries")
        assert isinstance(articles, list)
        print(f"TalkSport articles: {len(articles)}")
    
    def test_relevance_scoring(self, scraper):
        """Test that articles get relevance scores."""
        articles = scraper.scrape_all(sources=["espn_injuries"])
        
        for article in articles:
            assert 0 <= article.relevance_score <= 1
        
        if articles:
            print(f"Relevance scores: {[a.relevance_score for a in articles[:5]]}")
    
    def test_save_and_load(self, scraper):
        """Test saving and loading articles."""
        articles = scraper.scrape_all(sources=["espn_injuries"])
        
        if articles:
            scraper.save_articles(articles)
            loaded = scraper.get_recent_articles(hours=1, min_relevance=0.0)
            assert len(loaded) > 0
            print(f"Loaded from DB: {len(loaded)} articles")


class TestETLPipeline:
    """Test ETL pipeline."""
    
    @pytest.fixture
    def etl(self):
        return ETLPipeline()
    
    def test_process_empty_data(self, etl):
        """Test processing when no data exists."""
        df = etl.process_api_football(db_path="nonexistent.db")
        assert isinstance(df, pd.DataFrame)
        assert df.empty
    
    def test_generate_features_empty(self, etl):
        """Test feature generation with empty data."""
        df = etl.generate_match_features(
            pd.DataFrame(), 
            pd.DataFrame()
        )
        assert isinstance(df, pd.DataFrame)
        assert df.empty


class TestFeatureEngineer:
    """Test feature engineering."""
    
    @pytest.fixture
    def fe(self):
        return FeatureEngineer()
    
    def test_generate_form_features(self, fe):
        """Test form feature generation."""
        # Create sample match data
        matches = pd.DataFrame({
            "fixture_id": [1, 2, 3, 4, 5],
            "date": pd.to_datetime(["2024-01-01", "2024-01-02", "2024-01-03", "2024-01-04", "2024-01-05"]),
            "home_team_id": [1, 2, 1, 2, 1],
            "away_team_id": [2, 1, 2, 1, 2],
            "home_team_name": ["A", "B", "A", "B", "A"],
            "away_team_name": ["B", "A", "B", "A", "B"],
            "home_goals": [2, 1, 3, 0, 1],
            "away_goals": [1, 2, 1, 1, 0],
            "league_id": [1, 1, 1, 1, 1],
            "season": [2024, 2024, 2024, 2024, 2024]
        })
        
        form_df = fe.generate_team_form_features(matches, lookback=3)
        
        assert isinstance(form_df, pd.DataFrame)
        assert not form_df.empty
        assert "home_form_points_last_n" in form_df.columns
        assert "away_form_points_last_n" in form_df.columns
        
        print(f"Form features: {list(form_df.columns)}")
        print(form_df.head())
    
    def test_generate_h2h_features(self, fe):
        """Test H2H feature generation."""
        matches = pd.DataFrame({
            "fixture_id": [1, 2, 3],
            "date": pd.to_datetime(["2024-01-01", "2024-01-02", "2024-01-03"]),
            "home_team_id": [1, 2, 1],
            "away_team_id": [2, 1, 2],
            "home_goals": [2, 1, 3],
            "away_goals": [1, 2, 1]
        })
        
        h2h_df = fe.generate_h2h_features(matches)
        
        assert isinstance(h2h_df, pd.DataFrame)
        assert not h2h_df.empty
        assert "h2h_total" in h2h_df.columns
        
        print(f"H2H features: {list(h2h_df.columns)}")
        print(h2h_df.head())
    
    def test_generate_targets(self, fe):
        """Test target variable generation."""
        matches = pd.DataFrame({
            "fixture_id": [1, 2, 3],
            "home_goals": [2, 1, 0],
            "away_goals": [1, 1, 3]
        })
        
        targets = fe.generate_target_variables(matches)
        
        assert isinstance(targets, pd.DataFrame)
        assert not targets.empty
        assert "outcome" in targets.columns
        assert "btts" in targets.columns
        assert "over_2_5" in targets.columns
        
        # Check outcomes: 2=home win, 1=draw, 0=away win
        assert targets.iloc[0]["outcome"] == 2  # 2-1
        assert targets.iloc[1]["outcome"] == 1  # 1-1
        assert targets.iloc[2]["outcome"] == 0  # 0-3
        
        print(f"Targets: {targets.to_dict('records')}")


if __name__ == "__main__":
    pytest.main([__file__, "-v", "--tb=short"])
