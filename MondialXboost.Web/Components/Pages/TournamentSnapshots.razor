@page "/tournament/snapshots"
@rendermode InteractiveServer
@inject SnapshotService Snapshots
@inject MondialXboostDbContext Db
@inject ISnackbar Snackbar

<PageTitle>Snapshots de torneo</PageTitle>

<MudStack Spacing="3">
    <div class="page-head">
        <MudText Typo="Typo.h3">Snapshots de torneo</MudText>
        <MudText Typo="Typo.body1" Color="Color.Secondary">Simulaciones Monte Carlo guardadas para revisar proyecciones anteriores sin volver a correr el torneo.</MudText>
    </div>

    <MudPaper Class="surface-card" Elevation="0">
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="action-row">
            <MudText Typo="Typo.h6">Snapshots guardados</MudText>
            <MudSpacer />
            <MudButton Href="tournament" Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.EmojiEvents">Volver al torneo</MudButton>
            <MudTooltip Text="Actualizar snapshots">
                <MudIconButton Icon="@Icons.Material.Filled.Refresh" Color="Color.Primary" Disabled="_loadingSnapshot" OnClick="RefreshSnapshots" />
            </MudTooltip>
        </MudStack>
        @if (!_snapshotsLoaded)
        {
            <MudSkeleton Height="34px" Class="skeleton-row" />
            <MudSkeleton Height="34px" Class="skeleton-row" />
        }
        else if (_snapshots.Count == 0)
        {
            <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">Todavía no hay snapshots de torneo guardados.</MudAlert>
        }
        else
        {
            <MudTable Items="_snapshots" Dense="true" Hover="true" Elevation="0" Class="dense-table">
                <HeaderContent>
                    <MudTh>Fecha</MudTh>
                    <MudTh>Modelo</MudTh>
                    <MudTh Class="num">Simulaciones</MudTh>
                    <MudTh>Hash</MudTh>
                    <MudTh>Estado</MudTh>
                    <MudTh></MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Fecha">@context.CreatedAt.ToLocalTime().ToString("g")</MudTd>
                    <MudTd DataLabel="Modelo">@context.ModelName</MudTd>
                    <MudTd DataLabel="Simulaciones" Class="num">@(context.Simulations?.ToString("N0") ?? "-")</MudTd>
                    <MudTd DataLabel="Hash">@ShortHash(context.InputSummaryHash)</MudTd>
                    <MudTd DataLabel="Estado">
                        @if (context.IsValid)
                        {
                            <MudChip T="string" Size="Size.Small" Color="Color.Success" Variant="Variant.Outlined">Listo</MudChip>
                        }
                        else
                        {
                            <MudTooltip Text="@context.Error">
                                <MudChip T="string" Size="Size.Small" Color="Color.Warning" Variant="Variant.Outlined">No disponible</MudChip>
                            </MudTooltip>
                        }
                    </MudTd>
                    <MudTd Class="action-cell">
                        <MudButton Size="Size.Small"
                                   Variant="Variant.Outlined"
                                   Color="@(_activeSnapshotId == context.Id ? Color.Primary : Color.Default)"
                                   StartIcon="@Icons.Material.Filled.Visibility"
                                   Disabled="_loadingSnapshot || !context.IsValid"
                                   OnClick="@(() => LoadSnapshot(context))">
                            @(_activeSnapshotId == context.Id ? "Viendo" : "Ver")
                        </MudButton>
                    </MudTd>
                </RowTemplate>
            </MudTable>
        }
    </MudPaper>

    @if (!string.IsNullOrWhiteSpace(_error))
    {
        <MudAlert Severity="Severity.Error" Variant="Variant.Outlined">@_error</MudAlert>
    }

    @if (_projection is not null)
    {
        <MudPaper Class="surface-card" Elevation="0">
            <MudText Typo="Typo.h6">Probabilidad de campeón</MudText>
            <MudText Typo="Typo.caption" Color="Color.Secondary">@_projectionSource | @_projection.Simulations.ToString("N0") simulaciones | @_projection.InputSummaryHash</MudText>
            <MudTable Items="_projection.Teams.Take(32)" Dense="true" Hover="true" Elevation="0" Class="dense-table">
                <HeaderContent>
                    <MudTh>Equipo</MudTh>
                    <MudTh Class="num">Clasifica</MudTh>
                    <MudTh Class="num">16avos</MudTh>
                    <MudTh Class="num">4tos</MudTh>
                    <MudTh Class="num">Semis</MudTh>
                    <MudTh Class="num">Final</MudTh>
                    <MudTh Class="num">Campeón</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Equipo"><TeamLabel TeamId="@context.TeamId" Name="@Name(context.TeamId)" /></MudTd>
                    <MudTd DataLabel="Clasifica" Class="num">@context.Qualify.ToString("P0")</MudTd>
                    <MudTd DataLabel="16avos" Class="num">@context.ReachRoundOf16.ToString("P0")</MudTd>
                    <MudTd DataLabel="4tos" Class="num">@context.ReachQuarterFinal.ToString("P0")</MudTd>
                    <MudTd DataLabel="Semis" Class="num">@context.ReachSemiFinal.ToString("P0")</MudTd>
                    <MudTd DataLabel="Final" Class="num">@context.ReachFinal.ToString("P0")</MudTd>
                    <MudTd DataLabel="Campeón" Class="num"><strong>@context.WinTournament.ToString("P1")</strong></MudTd>
                </RowTemplate>
            </MudTable>
        </MudPaper>
    }
</MudStack>

@code {
    private bool _loadingSnapshot;
    private bool _snapshotsLoaded;
    private string _error = "";
    private string _projectionSource = "";
    private int? _activeSnapshotId;
    private TournamentProjection? _projection;
    private IReadOnlyList<TournamentSnapshotSummary> _snapshots = [];
    private Dictionary<string, string> _names = [];

    protected override async Task OnInitializedAsync()
    {
        _names = await Db.Teams.ToDictionaryAsync(t => t.Id, t => t.Name);
        await RefreshSnapshots();
    }

    private async Task RefreshSnapshots()
    {
        _snapshotsLoaded = false;
        try
        {
            _snapshots = await Snapshots.TournamentSnapshotsAsync();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
            Snackbar.Add("No se pudieron cargar los snapshots.", Severity.Error);
        }
        finally
        {
            _snapshotsLoaded = true;
        }
    }

    private async Task LoadSnapshot(TournamentSnapshotSummary summary)
    {
        if (!summary.IsValid)
        {
            Snackbar.Add(summary.Error ?? "El snapshot no está disponible.", Severity.Warning);
            return;
        }

        _loadingSnapshot = true;
        _error = "";
        try
        {
            var result = await Snapshots.LoadTournamentSnapshotAsync(summary.Id);
            if (!result.IsValid || result.Projection is null)
            {
                _error = result.Error ?? "No se pudo leer el snapshot.";
                Snackbar.Add(_error, Severity.Error);
                return;
            }

            _projection = result.Projection;
            _projectionSource = $"Snapshot guardado {summary.CreatedAt.ToLocalTime():g}";
            _activeSnapshotId = summary.Id;
            Snackbar.Add("Snapshot cargado.", Severity.Success);
        }
        catch (Exception ex)
        {
            _error = ex.Message;
            Snackbar.Add("No se pudo cargar el snapshot.", Severity.Error);
        }
        finally
        {
            _loadingSnapshot = false;
        }
    }

    private string Name(string id) => _names.TryGetValue(id, out var name) ? name : id;

    private static string ShortHash(string hash) =>
        string.IsNullOrWhiteSpace(hash) ? "-" : hash[..Math.Min(12, hash.Length)];
}
