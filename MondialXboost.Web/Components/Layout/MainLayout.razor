@inherits LayoutComponentBase

<MudThemeProvider Theme="_theme" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="0" Dense="true" Class="topbar">
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start" OnClick="ToggleDrawer" />
        <MudText Typo="Typo.h6" Class="app-title">Oloráculo</MudText>
        <MudSpacer />
        <MudChip T="string" Color="Color.Primary" Variant="Variant.Outlined" Size="Size.Small">Oráculo mundialista</MudChip>
    </MudAppBar>

    <MudDrawer @bind-Open="_drawerOpen" ClipMode="DrawerClipMode.Always" Elevation="0" Variant="DrawerVariant.Responsive" Class="app-drawer">
        <NavMenu />
    </MudDrawer>

    <MudMainContent Class="main-content">
        <MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="page-container">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

<div id="blazor-error-ui" data-nosnippet>
    Ocurrió un error inesperado.
    <a href="." class="reload">Recargar</a>
    <span class="dismiss">x</span>
</div>

@code {
    private bool _drawerOpen = true;

    private readonly MudTheme _theme = new()
    {
        PaletteLight = new PaletteLight
        {
            Primary = "#126a5a",
            Secondary = "#315a9f",
            Tertiary = "#c98926",
            Background = "#f5f7fb",
            Surface = "#ffffff",
            AppbarBackground = "#172033",
            AppbarText = "#ffffff",
            DrawerBackground = "#ffffff",
            DrawerText = "#172033",
            TextPrimary = "#172033",
            TextSecondary = "#667085",
            Divider = "#d8dee8",
            Success = "#21724d",
            Error = "#a83f45",
            Warning = "#c98926"
        },
        LayoutProperties = new LayoutProperties
        {
            DefaultBorderRadius = "8px"
        },
        Typography = new Typography
        {
            Default = new DefaultTypography
            {
                FontFamily = ["Inter", "ui-sans-serif", "system-ui", "Segoe UI", "sans-serif"]
            }
        }
    };

    private void ToggleDrawer() => _drawerOpen = !_drawerOpen;
}
