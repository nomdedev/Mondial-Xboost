<div class="prob" role="img" aria-label="@AriaLabel">
    <div class="seg home" style="width:@Pct(Outcome.HomeWin)">@Label(Outcome.HomeWin)</div>
    <div class="seg draw" style="width:@Pct(Outcome.Draw)">@Label(Outcome.Draw)</div>
    <div class="seg away" style="width:@Pct(Outcome.AwayWin)">@Label(Outcome.AwayWin)</div>
</div>
<div class="legend">
    <span><TeamLabel TeamId="@HomeTeamId" Name="@HomeLabel" Compact="true" /> @Outcome.HomeWin.ToString("P0")</span>
    <span>Empate @Outcome.Draw.ToString("P0")</span>
    <span><TeamLabel TeamId="@AwayTeamId" Name="@AwayLabel" Compact="true" /> @Outcome.AwayWin.ToString("P0")</span>
</div>

@code {
    [Parameter] public OutcomeProbabilities Outcome { get; set; }
    [Parameter] public string HomeLabel { get; set; } = "Local";
    [Parameter] public string AwayLabel { get; set; } = "Visitante";
    [Parameter] public string? HomeTeamId { get; set; }
    [Parameter] public string? AwayTeamId { get; set; }

    private static string Pct(double value) => $"{Math.Max(value * 100, 0):0.###}%";
    private static string Label(double value) => value >= .08 ? value.ToString("P0") : "";
    private string AriaLabel => $"{HomeLabel} {Outcome.HomeWin:P0}, empate {Outcome.Draw:P0}, {AwayLabel} {Outcome.AwayWin:P0}";
}
